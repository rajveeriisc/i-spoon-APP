# ===========================================
# iSpoon Backend Environment Configuration
# ===========================================
# Copy this file to .env and fill in real values.
# Variables marked REQUIRED must be set or the server will not start.

# Application
NODE_ENV=development            # REQUIRED: development | production
PORT=5000
APP_NAME=SmartSpoon
APP_BASE_URL=http://localhost:5000

# Database (NeonDB PostgreSQL)
DATABASE_URL=postgresql://username:password@host:5432/database  # REQUIRED

# JWT Tokens — use a strong random string (min 32 chars) for both
JWT_SECRET=CHANGE_ME_to_a_random_32plus_char_string              # REQUIRED
JWT_REFRESH_SECRET=CHANGE_ME_to_a_different_random_32plus_string # REQUIRED
JWT_EXPIRY=7d

# Firebase Admin SDK — path to your downloaded service account JSON
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/serviceAccount.json     # REQUIRED

# Email (Resend API — https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx                           # REQUIRED for email features
MAIL_FROM_ADDRESS=noreply@yourdomain.com

# CORS — comma-separated list of allowed frontend origins
# For mobile-only API this can be left as localhost only
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# Rate Limiting
# RATE_LIMIT_WINDOW_MS: window in milliseconds (900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS: max requests per window per IP (general routes)
RATE_LIMIT_MAX_REQUESTS=100
# AUTH_RATE_LIMIT_MAX: max auth attempts per window (stricter)
AUTH_RATE_LIMIT_MAX=5

# Password & Token Settings
PASSWORD_SALT_ROUNDS=12
PASSWORD_RESET_TOKEN_TTL_MINUTES=60
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=1440

# File Upload
MAX_FILE_SIZE=5242880    # 5MB in bytes
UPLOAD_DIR=./uploads
