# are required for builds but contain API keys. Keep them out of public repos.
ios/Runner/GoogleService-Info.plist
android/app/google-services.json
# firebase_options.dart is auto-generated — regenerate per environment
# lib/firebase_options.dart

# Environment & keys
*.env
*.pem
*.key
*.p12
